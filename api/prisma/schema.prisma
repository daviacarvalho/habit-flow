generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Habit {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  logs      HabitLog[]
}

model HabitLog {
  id      String @id @default(cuid())
  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date    String // YYYY-MM-DD format

  @@unique([habitId, date])
}
